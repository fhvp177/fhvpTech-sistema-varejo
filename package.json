{
  "name": "fhvptech-sistemas",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo dos sistemas FHVP Tech (núcleo compartilhado + apps por nicho)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:varejo": "npm run dev --workspace apps/varejo",
    "build:varejo": "npm run build --workspace apps/varejo",
    "dist:varejo:win": "npm run dist:win --workspace apps/varejo",
    "test": "npm run test --workspaces --if-present"
  }
}
